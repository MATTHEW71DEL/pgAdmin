<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="15" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.matv.ui.ProductController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <VBox spacing="10" HBox.hgrow="ALWAYS">
        <Label style="-fx-font-weight: bold;" text="Каталог таваров" />
        <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            <columns>
                <TableColumn fx:id="colName" text="Название" />
                <TableColumn fx:id="colPrice" text="Цена" />
                <TableColumn fx:id="colStock" text="Склад" />
                <TableColumn fx:id="colCategoryId" text="ID Категории" />
                <TableColumn fx:id="colState" prefWidth="120" text="Состояние" />
            </columns>
        </TableView>

        <Label style="-fx-font-weight: bold;" text="Информация о категории" />
        <ListView fx:id="hierarchyListView" prefHeight="150" />
    </VBox>

    <VBox alignment="BOTTOM_CENTER" minWidth="250" prefWidth="250" spacing="15">

        <VBox spacing="8" VBox.vgrow="ALWAYS">
            <Label style="-fx-font-weight: bold;" text="Данные товара" />
         <Label text="Название товара" />
            <TextField fx:id="txtName" promptText="Название товара" />
         <Label text="Цена" />
            <TextField fx:id="txtPrice" promptText="Цена" />
         <Label text="Количество" />
            <TextField fx:id="txtStock" promptText="Количество на складе" />
         <Label text="ID категории" />
            <TextField fx:id="txtCategoryId" promptText="ID Категории" />

            <Button maxWidth="Infinity" onAction="#handleAddLocal" text="Добавить" />
            <Button maxWidth="Infinity" onAction="#handleEditLocal" text="Применить правки" />
            <Button maxWidth="Infinity" onAction="#handleDeleteLocal" text="Удалить" />
            <Button maxWidth="Infinity" onAction="#handleCancelEdit" text="Отменить изменения" />

            <Button maxWidth="Infinity" onAction="#handleShowHierarchy" text="Обновить дерево связей">
                <VBox.margin>
                    <Insets />
                </VBox.margin>
            </Button>
            <Button maxWidth="Infinity" onAction="#handleRefresh" text="Прочитать из БД" />
            <Button maxWidth="Infinity" onAction="#handleSaveToDb" text="Сохранить в БД" />
        </VBox>

        <VBox spacing="10" />
    </VBox>
</HBox>