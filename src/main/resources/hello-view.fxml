<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox spacing="20" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.matv.ui.ClientController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <TableView fx:id="clientTable" prefHeight="400" prefWidth="400" HBox.hgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colSurname" text="Фамилия" />
            <TableColumn fx:id="colName" text="Имя" />
            <TableColumn fx:id="colPatronymic" text="Отчество" />
            <TableColumn fx:id="colPhone" text="Телефон" />
        </columns>
    </TableView>

    <VBox alignment="TOP_CENTER" minWidth="250" spacing="15">

        <VBox spacing="5">
            <Label style="-fx-font-weight: bold;" text="Данные клиента:" />

            <Label text="Фамилия:" />
            <TextField fx:id="txtSurname" promptText="Введите фамилию" />

            <Label text="Имя:" />
            <TextField fx:id="txtName" promptText="Введите имя" />

            <Label text="Отчество:" />
            <TextField fx:id="txtPatronymic" promptText="Введите отчество" />

            <Label text="Телефон:" />
            <TextField fx:id="txtPhone" promptText="Введите телефон" />
        </VBox>
          <Button maxWidth="Infinity" onAction="#handleAddLocal" text="Добавить локально" />
          <Button maxWidth="Infinity" onAction="#handleSaveToDb" text="Сохранить в БД" />
          <Button maxWidth="Infinity" onAction="#handleRefresh" text="Прочитать из БД" />

        <VBox alignment="CENTER_LEFT" spacing="10" />
    </VBox>
</HBox>
